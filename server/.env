# TRADEX Backend Environment Variables
# Generated: May 29, 2026

# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database Mode - Use File-Based Database (Instant, No Installation)
USE_FILE_DB=true

# MongoDB Atlas (Optional for production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tradex?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=tradex_super_secret_key_change_in_production_2025

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# API Keys for External Services (Optional)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# File Upload
MAX_FILE_SIZE=5000000
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
