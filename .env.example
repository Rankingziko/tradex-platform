# TRADEX Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ====================
# SERVER CONFIG
# ====================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ====================
# DATABASE CONFIG
# ====================
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/tradex

# OR MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tradex?retryWrites=true&w=majority

# ====================
# JWT AUTHENTICATION
# ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_EXPIRE=30d

# ====================
# EMAIL CONFIG (Nodemailer)
# ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@tradex.com
SMTP_SECURE=false

# ====================
# BINANCE API (Optional - for real market data)
# ====================
BINANCE_API_KEY=your-binance-api-key-here
BINANCE_API_SECRET=your-binance-api-secret-here

# ====================
# STRIPE PAYMENT CONFIG (Optional)
# ====================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ====================
# AWS S3 CONFIG (Optional - for file uploads)
# ====================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=tradex-bucket-name
AWS_REGION=us-east-1

# ====================
# REDIS CONFIG (Optional - for caching)
# ====================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ====================
# ADMIN CONFIG
# ====================
ADMIN_EMAIL=admin@tradex.com
ADMIN_PASSWORD=SecureAdminPassword123!

# ====================
# RATE LIMITING
# ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ====================
# SECURITY CONFIG
# ====================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ====================
# CRYPTO CONFIG
# ====================
CRYPTO_DEPOSIT_WALLET_BTC=1A1z7agoat2GPFH7pPmmCH5yAcSQxZWML
CRYPTO_DEPOSIT_WALLET_ETH=0x1234567890123456789012345678901234567890
CRYPTO_DEPOSIT_WALLET_USDT=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# ====================
# EMAIL VERIFICATION
# ====================
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_EXPIRE=24h

# ====================
# TWO-FACTOR AUTH
# ====================
TWO_FACTOR_ENABLED=true

# ====================
# FILE UPLOADS
# ====================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# ====================
# TRADING CONFIG
# ====================
MIN_TRADE_AMOUNT=10
MAX_TRADE_AMOUNT=1000000
DEFAULT_LEVERAGE=1
MAX_LEVERAGE=100

# ====================
# WITHDRAWAL CONFIG
# ====================
MIN_WITHDRAWAL_AMOUNT=50
WITHDRAWAL_FEE_PERCENT=0.5

# ====================
# API KEYS (External Services)
# ====================
COINGECKO_API_KEY=your-coingecko-api-key
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# ====================
# LOGGING
# ====================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ====================
# FEATURES (Feature Flags)
# ====================
FEATURE_DEMO_TRADES=true
FEATURE_REFERRAL_PROGRAM=true
FEATURE_VIP_MEMBERSHIP=true
FEATURE_TRADING_SIGNALS=true

# ====================
# ENVIRONMENT SPECIFIC
# ====================
ENVIRONMENT=development
# development | staging | production
