# TRADEX Backend Environment Configuration

# ====================
# SERVER CONFIG
# ====================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ====================
# DATABASE CONFIG
# ====================
MONGODB_URI=mongodb://localhost:27017/tradex

# ====================
# JWT AUTHENTICATION
# ====================
JWT_SECRET=tradex-secret-key-2024-secure-12345-change-in-production
JWT_EXPIRE=30d

# ====================
# EMAIL CONFIG (Nodemailer)
# ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@tradex.com
SMTP_SECURE=false

# ====================
# BINANCE API (Optional)
# ====================
BINANCE_API_KEY=your-binance-api-key-here
BINANCE_API_SECRET=your-binance-api-secret-here

# ====================
# STRIPE PAYMENT CONFIG (Optional)
# ====================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
